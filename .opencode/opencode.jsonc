{
  "$schema": "https://opencode.ai/config.json",

  "model": "opencode/minimax-m3-free",
  "small_model": "opencode/minimax-m3-free",

  "provider": {
    "opencode": {
      "name": "OpenCode Zen (Free Tier)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "minimax-m3-free": {
          "name": "MiniMax M3 Free"
        }
      }
    }
  },

  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-skills-collection@latest",
    "opencode-power-pack@git+https://github.com/amitdmore/opencode-power-pack.git",
    "ecc-universal@latest"
  ],

  "agent": {
    "build": {
      "model": "opencode/minimax-m3-free",
      "prompt": "{file:/workspaces/Coba/.opencode/agents/build.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "write": true,
        "read": true,
        "grep": true,
        "glob": true,
        "webfetch": false
      }
    },
    "plan": {
      "model": "opencode/minimax-m3-free",
      "prompt": "{file:/workspaces/Coba/.opencode/agents/plan.md}",
      "tools": {
        "bash": false,
        "edit": false,
        "write": false,
        "read": true,
        "grep": true,
        "glob": true
      }
    },
    "test": {
      "model": "opencode/minimax-m3-free",
      "prompt": "{file:/workspaces/Coba/.opencode/agents/test.md}",
      "tools": {
        "bash": true,
        "edit": false,
        "write": false,
        "read": true,
        "grep": true,
        "glob": true
      }
    },
    "fix": {
      "model": "opencode/minimax-m3-free",
      "prompt": "{file:/workspaces/Coba/.opencode/agents/fix.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "write": false,
        "read": true,
        "grep": true,
        "glob": true
      }
    },
    "review": {
      "model": "opencode/minimax-m3-free",
      "prompt": "{file:/workspaces/Coba/.opencode/agents/review.md}",
      "tools": {
        "bash": true,
        "edit": false,
        "write": false,
        "read": true,
        "grep": true,
        "glob": true
      }
    }
  },

  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "deny"
  },

  "compaction": {
    "auto": true,
    "reserveTokens": 4000
  },

  "experimental": {
    "openTelemetry": false,
    "disableCache": false
  },

  "formatter": false
}
