{
  "name": "UGC Swarm",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  },
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && pip install --upgrade pip && pip install -r ugc_ai_overpower/requirements.txt",
  "workspaceFolder": "/workspaces/ugc_ai_overpower",
  "workspaceMount": "source=${localWorkspaceFolder}/ugc_ai_overpower,target=/workspaces/ugc_ai_overpower,type=bind"
}
